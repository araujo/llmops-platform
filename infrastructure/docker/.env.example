# Runtime env is split at repo root:
# - .env.shared   -> platform/host/infra settings (this section)
# - .env.shopping -> shopping agent provider/model settings (see below)

# .env.shared
LLMOPS_MONGO_URI=mongodb://mongo:27017
LLMOPS_MONGO_DATABASE=llmops
LLMOPS_POSTGRES_DSN=postgresql://llmops:llmops@postgres:5432/llmops
LITELLM_MASTER_KEY=sk-local-dev
OPENAI_API_KEY=

# Langfuse (generate stronger values for non-local use)
LANGFUSE_NEXTAUTH_SECRET=replace_with_openssl_rand_base64_32
LANGFUSE_SALT=replace_with_openssl_rand_base64_32
LANGFUSE_ENCRYPTION_KEY=replace_with_openssl_rand_hex_32
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=

# .env.shopping
SHOPPING_ASSISTANT_LLM_PROVIDER=ollama
SHOPPING_ASSISTANT_LLM_MODEL=llama4
SHOPPING_ASSISTANT_OLLAMA_BASE_URL=http://host.docker.internal:11434
SHOPPING_ASSISTANT_OPENAI_API_KEY=
SHOPPING_ASSISTANT_ANTHROPIC_API_KEY=
