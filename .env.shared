# Shared platform runtime configuration (host + infra).
# Keep this file agent-agnostic.

# Host shared infrastructure
LLMOPS_MONGO_URI=mongodb://mongo:27017
LLMOPS_MONGO_DATABASE=llmops
LLMOPS_POSTGRES_DSN=postgresql://llmops:llmops@postgres:5432/llmops

# Optional tracing (Langfuse)
LANGFUSE_HOST=http://langfuse:3000
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
